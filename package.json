{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "lolka.js",
  "version": "0.3.0",
  "description": "A powerful library for interacting with the lolka bot API (discord.js-compatible fork)",
  "scripts": {
    "build": "node ./scripts/esmDts.mjs",
    "prepack": "npm run build"
  },
  "main": "./src/index.js",
  "types": "./typings/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./typings/index.d.mts",
        "default": "./src/index.js"
      },
      "require": {
        "types": "./typings/index.d.ts",
        "default": "./src/index.js"
      }
    }
  },
  "directories": {
    "lib": "src"
  },
  "files": [
    "src",
    "typings/*.d.ts",
    "typings/*.d.mts"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "discord",
    "api",
    "bot",
    "client",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lolka-App/lolka.js.git"
  },
  "bugs": {
    "url": "https://github.com/Lolka-App/lolka.js/issues"
  },
  "homepage": "https://github.com/Lolka-App/lolka.js",
  "dependencies": {
    "@discordjs/builders": "^1.14.1",
    "@discordjs/collection": "1.5.3",
    "@discordjs/formatters": "^0.6.2",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/util": "^1.2.0",
    "@discordjs/ws": "^1.2.3",
    "@roamhq/wrtc": "^0.10.0",
    "discord-api-types": "^0.38.40",
    "fast-deep-equal": "3.1.3",
    "lodash.snakecase": "4.1.1",
    "magic-bytes.js": "^1.13.0",
    "mediasoup-client": "^3.21.0",
    "prism-media": "^1.3.5",
    "tslib": "^2.6.3",
    "undici": "6.24.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "provenance": true
  }
}
