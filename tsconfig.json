{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": [
      "@discordjs/builders",
      "@discordjs/util",
      "@discordjs/collection",
      "@discordjs/rest",
      "@discordjs/ws",
      "discord-api-types/v10",
      "node",
      "undici"
    ]
  },
  "include": ["typings"]
}
